<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>I Z Z I E | Official Cyber Portal</title>
    <style>
        /* Global Reset & Futuristic Fonts */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
        }

        body {
            background-color: #060608;
            color: #D1D5DB;
            display: flex;
            justify-content: center;
            min-height: 100vh;
            padding: 40px 16px;
            overflow-x: hidden;
        }

        /* Main Container Framework */
        .portal-frame {
            max-width: 540px;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 48px;
        }

        /* Utility Layouts */
        section {
            width: 100%;
            position: relative;
        }

        .center-text {
            text-align: center;
        }

        /* Branding Header */
        .profile-wrapper {
            position: relative;
            display: inline-block;
            margin-bottom: 24px;
        }

        .avatar-glow {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #FF007F;
            box-shadow: 0 0 20px rgba(255, 0, 127, 0.4), inset 0 0 10px rgba(255, 0, 127, 0.2);
        }

        h1 {
            font-size: 2.8rem;
            font-weight: 200;
            letter-spacing: 0.7rem;
            color: #FFFFFF;
            text-transform: uppercase;
            margin-bottom: 6px;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
        }

        .artist-tags {
            font-size: 0.75rem;
            letter-spacing: 0.2rem;
            color: #00FFFF;
            text-transform: uppercase;
            text-shadow: 0 0 8px rgba(0, 255, 255, 0.3);
        }

        /* Section Typography */
        .terminal-header {
            font-size: 0.8rem;
            letter-spacing: 0.25rem;
            color: #6B7280;
            text-transform: uppercase;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .terminal-header::after {
            content: '';
            flex-grow: 1;
            height: 1px;
            background: linear-gradient(90deg, rgba(107, 114, 128, 0.3), transparent);
        }

        /* Connected Node Maps (Links) */
        .nodes-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .cyber-node {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 24px;
            background: rgba(13, 13, 18, 0.6);
            border: 1px solid rgba(255, 0, 127, 0.2);
            border-radius: 10px;
            color: #E5E7EB;
            text-decoration: none;
            font-size: 0.9rem;
            letter-spacing: 0.12rem;
            text-transform: uppercase;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(8px);
        }

        .cyber-node:hover {
            border-color: #FF007F;
            color: #FFFFFF;
            background: rgba(20, 15, 25, 0.8);
            box-shadow: 0 0 15px rgba(255, 0, 127, 0.3);
            transform: translateY(-2px);
        }

        .node-arrow {
            font-size: 0.8rem;
            color: #6B7280;
            transition: transform 0.3s ease;
        }

        .cyber-node:hover .node-arrow {
            color: #FF007F;
            transform: translateX(4px);
        }

        /* Featured Release Card Structure */
        .release-vault {
            background: linear-gradient(145deg, rgba(18, 18, 24, 0.7), rgba(10, 10, 14, 0.9));
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 32px 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
        }

        .release-meta {
            margin-bottom: 24px;
        }

        .release-title {
            font-size: 1.5rem;
            letter-spacing: 0.15rem;
            color: #FFFFFF;
            font-weight: 400;
            text-transform: uppercase;
        }

        .release-type {
            font-size: 0.8rem;
            color: #6B7280;
            letter-spacing: 0.1rem;
            text-transform: uppercase;
            margin-top: 4px;
        }

        /* Detailed Tracklist Breakdown */
        .tracklist {
            display: flex;
            flex-direction: column;
            gap: 2px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
            padding: 8px 0;
        }

        .track-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            border-radius: 6px;
            transition: background 0.2s ease;
        }

        .track-row:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .track-info {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .track-num {
            font-size: 0.8rem;
            color: #4B5563;
            min-width: 18px;
        }

        .track-name {
            font-size: 0.95rem;
            color: #9CA3AF;
            letter-spacing: 0.05rem;
        }

        .track-row.featured .track-name {
            color: #FF007F;
            font-weight: 500;
        }

        .track-length {
            font-size: 0.8rem;
            color: #4B5563;
        }

        /* Bio Statement Module */
        .bio-block {
            background: rgba(10, 10, 14, 0.4);
            border-left: 2px solid #00FFFF;
            padding: 16px 24px;
            border-radius: 0 12px 12px 0;
        }

        .bio-text {
            font-size: 0.95rem;
            line-height: 1.7;
            color: #9CA3AF;
            letter-spacing: 0.02rem;
        }

        /* Future Data Node Placeholder */
        .incoming-signal {
            border: 1px dashed rgba(107, 114, 128, 0.2);
            border-radius: 12px;
            padding: 24px;
            background: rgba(0, 0, 0, 0.1);
        }

        .signal-text {
            font-size: 0.8rem;
            letter-spacing: 0.15rem;
            color: #4B5563;
            text-transform: uppercase;
        }

        /* Footer Metadata */
        .portal-footer {
            font-size: 0.7rem;
            letter-spacing: 0.15rem;
            color: #374151;
            text-transform: uppercase;
            padding: 24px 0;
        }

        /* HARD CRUSH: Prevents the platform badge from drawing layout components */
        [class*="v0-badge"], 
        #v0-badge-container, 
        .v0-watermark,
        [data-v0-badge] {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
            pointer-events: none !important;
        }
    </style>
</head>
<body>

    <div class="portal-frame">
        
        <!-- Identity Module -->
        <header class="center-text">
            <div class="profile-wrapper">
                <!-- Replace with direct asset link when deploying -->
                <img src="https://via.placeholder.com/150" alt="I Z Z I E" class="avatar-glow">
            </div>
            <h1>I Z Z I E</h1>
            <div class="artist-tags">Alternative Pop // Electronic // Cyber Noir</div>
        </header>

        <!-- Connected Platforms -->
        <section>
            <div class="terminal-header">Connected Nodes</div>
            <div class="nodes-grid">
                <a href="https://spotify.com" class="cyber-node" target="_blank">
                    <span>Spotify</span>
                    <span class="node-arrow">➔</span>
                </a>
                <a href="https://music.apple.com" class="cyber-node" target="_blank">
                    <span>Apple Music</span>
                    <span class="node-arrow">➔</span>
                </a>
                <a href="https://amazon.com" class="cyber-node" target="_blank">
                    <span>Amazon Music</span>
                    <span class="node-arrow">➔</span>
                </a>
                <a href="https://youtube.com" class="cyber-node" target="_blank">
                    <span>YouTube</span>
                    <span class="node-arrow">➔</span>
                </a>
                <a href="https://tiktok.com" class="cyber-node" target="_blank">
                    <span>TikTok</span>
                    <span class="node-arrow">➔</span>
                </a>
            </div>
        </section>

        <!-- Catalog Track Spotlight -->
        <section>
            <div class="terminal-header">Current Audio Core</div>
            <div class="release-vault">
                <div class="release-meta">
                    <div class="release-title">Journal Notes</div>
                    <div class="release-type">EP // 4 Tracks</div>
                </div>
                
                <div class="tracklist">
                    <div class="track-row featured">
                        <div class="track-info">
                            <span class="track-num">01</span>
                            <span class="track-name">I Am The Table</span>
                        </div>
                        <span class="track-length">MAIN</span>
                    </div>
                    <div class="track-row">
                        <div class="track-info">
                            <span class="track-num">02</span>
                            <span class="track-name">Track Two</span>
                        </div>
                        <span class="track-length">--:--</span>
                    </div>
                    <div class="track-row">
                        <div class="track-info">
                            <span class="track-num">03</span>
                            <span class="track-name">Track Three</span>
                        </div>
                        <span class="track-length">--:--</span>
                    </div>
                    <div class="track-row">
                        <div class="track-info">
                            <span class="track-num">04</span>
                            <span class="track-name">Track Four</span>
                        </div>
                        <span class="track-length">--:--</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Identity Profile Statement -->
        <section>
            <div class="terminal-header">Artist Manifesto</div>
            <div class="bio-block">
                <p class="bio-text">
                    Independent recording artist creating alternative pop, electronic frequencies, visual art, and immersive digital landscapes. Pushing sonic limitations through high-saturation sound design.
                </p>
            </div>
        </section>

        <!-- Future Archive Anchor -->
        <section class="center-text">
            <div class="terminal-header">Incoming Transmission</div>
            <div class="incoming-signal">
                <div class="signal-text">[ Project: Heavy Saturation Pending ]</div>
            </div>
        </section>

        <!-- System Footer Metadata -->
        <footer class="center-text portal-footer">
            © 2026 I Z Z I E // Cryptographic Network Registry
        </footer>

    </div>

    <!-- Active Mutation Script to scrub layout injection scripts and frames -->
    <script>
        const cleanWatermarks = () => {
            const trash = document.querySelectorAll('[class*="v0-badge"], #v0-badge-container, .v0-watermark, [data-v0-badge]');
            trash.forEach(item => item.remove());
        };
        cleanWatermarks();
        const systemObserver = new MutationObserver(cleanWatermarks);
        systemObserver.observe(document.body, { childList: true, subtree: true });
    </script>
</body>
</html>
